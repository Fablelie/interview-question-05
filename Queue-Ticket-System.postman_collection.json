    {
      "name": "Get Next Ticket #1",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// 1. ตั้งค่าเริ่มต้นระบุจำนวนรอบที่ต้องการยิงคำสั่ง (รอบแรกยังไม่มีค่า ให้เซตเป็น 50)\r",
              "if (!pm.variables.has(\"loop_counter\")) {\r",
              "    pm.variables.set(\"loop_counter\", 100);\r",
              "}\r",
              "\r",
              "// 2. ดึงค่าตัวนับรอบปัจจุบันมาใช้งาน\r",
              "let counter = pm.variables.get(\"loop_counter\");\r",
              "\r",
              "// 3. แสดงบันทึกข้อมูลใน Console เพื่อเอาไว้ตรวจสอบรอบการทำงาน\r",
              "console.log(\"จำนวนรอบที่เหลือ: \" + counter + \" รอบ\");\r",
              "\r",
              "// 4. เงื่อนไขในการสั่งรันซ้ำ\r",
              "if (counter > 1) {\r",
              "    // ลบจำนวนรอบออกทีละ 1\r",
              "    pm.variables.set(\"loop_counter\", counter - 1);\r",
              "    \r",
              "    // สั่งให้ Postman วิ่งกลับมาเรียกยิง Request ปัจจุบันนี้ใหม่อีกครั้ง\r",
              "    postman.setNextRequest(pm.info.requestName);\r",
              "} else {\r",
              "    // เมื่อทำงานครบ 50 รอบแล้ว ให้ล้างตัวแปรทิ้งเพื่อเปิดทางให้การรันครั้งใหม่ในอนาคต\r",
              "    pm.variables.unset(\"loop_counter\");\r",
              "    postman.setNextRequest(null);\r",
              "}\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/tickets/next",
          "host": [
